# Public values supplied by the Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only FastAPI origin. Never prefix this value with NEXT_PUBLIC_.
FASTAPI_URL=http://127.0.0.1:8000

# Local-only deterministic fallback. Set false in production.
NEXT_PUBLIC_ENABLE_DEMO_MODE=true

# Server-only. Enables AI-written Amazon go-to-market kits (listing, brand,
# promotion plan). If neither key is set, the app falls back to an offline
# deterministic generator. Never prefix these with NEXT_PUBLIC_.
#
# Free option (recommended): Google Gemini free tier — get a key at
# https://aistudio.google.com/apikey . If set, it is used first.
GEMINI_API_KEY=replace-me
# Paid option: Anthropic Claude. Used only if GEMINI_API_KEY is not set.
ANTHROPIC_API_KEY=sk-ant-replace-me
